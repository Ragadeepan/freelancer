PORT=4000
# Comma-separated list of allowed frontend domains
FRONTEND_ORIGIN=http://localhost:5173,https://your-domain.com
# Public backend domain used for generated file URLs
BACKEND_PUBLIC_URL=http://localhost:4000
ENABLE_LOCAL_UPLOAD_FALLBACK=true

# Firebase Admin credentials (use one of the below)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=

# Payment gateway keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PAYOUT_ACCOUNT_NUMBER=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform defaults
DEFAULT_COMMISSION_PERCENT=10
