[debug] [2026-03-04T04:35:02.687Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/freelancer-99659/rulesets {"name":"projects/freelancer-99659/rulesets/fa0574cb-0415-40a3-b392-d846c38500db","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function userDoc() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid));\n    }\n\n    function isAdmin() {\n      return signedIn() && userDoc().data.role == \"admin\";\n    }\n\n    function isClient() {\n      return signedIn() && userDoc().data.role == \"client\";\n    }\n\n    function isFreelancer() {\n      return signedIn() && userDoc().data.role == \"freelancer\";\n    }\n\n    function isClientApproved() {\n      return isClient()\n        && userDoc().data.status == \"approved\"\n        && userDoc().data.profileCompletion == 100;\n    }\n\n    function isFreelancerApproved() {\n      return isFreelancer()\n        && userDoc().data.status == \"approved\"\n        && userDoc().data.profileCompletion == 100;\n    }\n\n    function hasText(value) {\n      return value is string && value.size() > 0;\n    }\n\n    function validNotificationCreatePayload() {\n      return request.resource.data.recipientId is string\n        && request.resource.data.recipientId.size() > 0\n        && request.resource.data.type is string\n        && request.resource.data.type.size() > 0\n        && request.resource.data.title is string\n        && request.resource.data.message is string\n        && request.resource.data.read is bool\n        && request.resource.data.read == false\n        && request.resource.data.createdAt == request.time;\n    }\n\n    function isNotificationActorWrite() {\n      return signedIn()\n        && request.resource.data.actorId == request.auth.uid\n        && validNotificationCreatePayload();\n    }\n\n    function hasFreelancerPortfolio() {\n      return (userDoc().data.portfolioLinks is list\n          && userDoc().data.portfolioLinks.size() > 0)\n        || hasText(userDoc().data.portfolioLink)\n        || hasText(userDoc().data.portfolio);\n    }\n\n    function hasFreelancerResume() {\n      return (userDoc().data.resume is map\n          && userDoc().data.resume.url is string\n          && userDoc().data.resume.url.size() > 0)\n        || hasText(userDoc().data.resumeUrl);\n    }\n\n    function hasFreelancerGovId() {\n      return (userDoc().data.govIdProof is map\n          && userDoc().data.govIdProof.url is string\n          && userDoc().data.govIdProof.url.size() > 0)\n        || hasText(userDoc().data.govIdProofUrl);\n    }\n\n    function hasFreelancerSkills() {\n      return (userDoc().data.primarySkills is list\n          && userDoc().data.primarySkills.size() >= 3);\n    }\n\n    function hasFreelancerName() {\n      return hasText(userDoc().data.name)\n        || hasText(userDoc().data.displayName)\n        || hasText(userDoc().data.fullName);\n    }\n\n    function hasFreelancerPhone() {\n      return hasText(userDoc().data.phone)\n        || hasText(userDoc().data.contactPhone)\n        || hasText(userDoc().data.mobile);\n    }\n\n    function hasFreelancerProfileImage() {\n      return hasText(userDoc().data.photoURL)\n        || hasText(userDoc().data.profileImage);\n    }\n\n    function hasFreelancerAbout() {\n      return hasText(userDoc().data.bio)\n        || hasText(userDoc().data.about);\n    }\n\n    function hasFreelancerHourlyRate() {\n      return hasText(userDoc().data.hourlyRate);\n    }\n\n    function isFreelancerReadyForMarketplace() {\n      return isFreelancerApproved()\n        && hasFreelancerName()\n        && hasFreelancerPhone()\n        && hasFreelancerProfileImage()\n        && hasFreelancerSkills()\n        && hasText(userDoc().data.experience)\n        && hasFreelancerHourlyRate()\n        && hasFreelancerAbout()\n        && hasFreelancerPortfolio()\n        && hasFreelancerResume();\n    }\n\n    function jobDoc(jobId) {\n      return get(/databases/$(database)/documents/jobs/$(jobId));\n    }\n\n    function proposalDoc(proposalId) {\n      return get(/databases/$(database)/documents/proposals/$(proposalId));\n    }\n\n    function projectDoc(projectId) {\n      return get(/databases/$(database)/documents/projects/$(projectId));\n    }\n\n    function contractDoc(contractId) {\n      return get(/databases/$(database)/documents/contracts/$(contractId));\n    }\n\n    function isContractMember(contractId) {\n      return signedIn()\n        && (contractDoc(contractId).data.clientId == request.auth.uid\n          || contractDoc(contractId).data.freelancerId == request.auth.uid);\n    }\n\n    function isProjectMember(projectId) {\n      return signedIn()\n        && (projectDoc(projectId).data.clientId == request.auth.uid\n          || projectDoc(projectId).data.freelancerId == request.auth.uid);\n    }\n\n    function isConnectedProject(projectId) {\n      return projectDoc(projectId).data.status == \"connected\";\n    }\n\n    function isConnectedProjectMember(projectId) {\n      return isProjectMember(projectId)\n        && isConnectedProject(projectId);\n    }\n\n    match /users/{userId} {\n      allow create: if signedIn()\n        && request.auth.uid == userId\n        && request.resource.data.id == userId;\n      allow read: if isAdmin() || request.auth.uid == userId;\n      allow list: if isAdmin();\n      allow update: if isAdmin()\n        || (request.auth.uid == userId\n          && request.resource.data.id == userId\n          && request.resource.data.role == resource.data.role\n          && (\n            (\n              request.resource.data.status == resource.data.status\n              && (\n                request.resource.data.status != \"approved\"\n                || request.resource.data.profileCompletion == 100\n              )\n            )\n            || (\n              request.resource.data.status == \"pending_approval\"\n              && resource.data.status in [\"incomplete\", \"rejected\", \"pending_approval\"]\n              && request.resource.data.profileCompletion == 100\n            )\n            || (\n              request.resource.data.status == \"incomplete\"\n              && resource.data.status in [\"incomplete\", \"rejected\", \"pending_approval\", \"approved\"]\n              && request.resource.data.profileCompletion < 100\n            )\n          ));\n      allow delete: if false;\n    }\n\n    match /bankDetails/{userId} {\n      allow create: if signedIn()\n        && request.auth.uid == userId\n        && request.resource.data.userId == userId\n        && request.resource.data.status == \"pending\";\n      allow read: if isAdmin() || request.auth.uid == userId;\n      allow update: if isAdmin()\n        || (signedIn()\n          && request.auth.uid == userId\n          && request.resource.data.userId == userId\n          && request.resource.data.status == \"pending\"\n          && request.resource.data.verifiedByAdminId == resource.data.verifiedByAdminId\n          && request.resource.data.verifiedAt == resource.data.verifiedAt);\n      allow delete: if false;\n    }\n\n    match /jobs/{jobId} {\n      allow create: if isClientApproved()\n        && request.resource.data.clientId == request.auth.uid\n        && request.resource.data.status == \"pending\";\n      allow read: if resource.data.status == \"approved\"\n        || isAdmin()\n        || (isClient() && resource.data.clientId == request.auth.uid)\n        || (isFreelancerApproved() && resource.data.status == \"approved\");\n      allow update: if isAdmin()\n        || (isClientApproved()\n          && resource.data.clientId == request.auth.uid\n          && resource.data.status == \"approved\"\n          && !hasText(resource.data.selectedProposalId)\n          && request.resource.data.clientId == resource.data.clientId\n          && request.resource.data.status == \"hired\"\n          && hasText(request.resource.data.selectedProposalId)\n          && hasText(request.resource.data.selectedFreelancerId)\n          && hasText(request.resource.data.projectId)\n          && request.resource.data.visibleToFreelancers == false\n          && request.resource.data.isClosed == true\n          && request.resource.data.hiredAt == request.time\n          && request.resource.data.closedAt == request.time\n          && request.resource.data.updatedAt == request.time\n          && proposalDoc(request.resource.data.selectedProposalId).data.jobId == jobId\n          && proposalDoc(request.resource.data.selectedProposalId).data.clientId\n            == request.auth.uid\n          && proposalDoc(request.resource.data.selectedProposalId).data.freelancerId\n            == request.resource.data.selectedFreelancerId\n          && proposalDoc(request.resource.data.selectedProposalId).data.status\n            in [\"pending\", \"approved\"]\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n            \"status\",\n            \"selectedProposalId\",\n            \"selectedFreelancerId\",\n            \"selectedFreelancerName\",\n            \"projectId\",\n            \"hiredAt\",\n            \"closedAt\",\n            \"isClosed\",\n            \"visibleToFreelancers\",\n            \"updatedAt\"\n          ]));\n      allow delete: if isAdmin();\n    }\n\n    match /proposals/{proposalId} {\n      allow create: if isFreelancerReadyForMarketplace()\n        && request.resource.data.freelancerId == request.auth.uid\n        && request.resource.data.status == \"pending\"\n        && request.resource.data.clientId\n          == jobDoc(request.resource.data.jobId).data.clientId\n        && jobDoc(request.resource.data.jobId).data.status == \"approved\";\n      allow read: if isAdmin()\n        || (isFreelancer() && resource.data.freelancerId == request.auth.uid)\n        || (isClient()\n          && (\n            resource.data.clientId == request.auth.uid\n            || jobDoc(resource.data.jobId).data.clientId == request.auth.uid\n          ));\n      allow update: if isAdmin()\n        || (isClientApproved()\n          && jobDoc(resource.data.jobId).data.clientId == request.auth.uid\n          && request.resource.data.jobId == resource.data.jobId\n          && request.resource.data.clientId == resource.data.clientId\n          && request.resource.data.freelancerId == resource.data.freelancerId\n          && resource.data.status in [\"pending\", \"approved\"]\n          && request.resource.data.updatedAt == request.time\n          && (\n            (request.resource.data.status == \"selected\"\n              && request.resource.data.selectedAt == request.time\n              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n                \"status\",\n                \"selectedAt\",\n                \"updatedAt\"\n              ]))\n            || (request.resource.data.status == \"not_selected\"\n              && request.resource.data.notSelectedAt == request.time\n              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n                \"status\",\n                \"notSelectedAt\",\n                \"updatedAt\"\n              ]))\n          ));\n      allow delete: if isAdmin();\n    }\n\n    match /projects/{projectId} {\n      allow create: if isAdmin()\n        || (isClientApproved()\n          && request.resource.data.clientId == request.auth.uid\n          && request.resource.data.status == \"assigned\"\n          && hasText(request.resource.data.jobId)\n          && hasText(request.resource.data.proposalId)\n          && hasText(request.resource.data.freelancerId)\n          && request.resource.data.connectedAt == null\n          && request.resource.data.connectedBy == null\n          && request.resource.data.createdAt == request.time\n          && request.resource.data.updatedAt == request.time\n          && request.resource.data.keys().hasAll([\n            \"jobId\",\n            \"clientId\",\n            \"freelancerId\",\n            \"proposalId\",\n            \"status\",\n            \"createdAt\",\n            \"updatedAt\",\n            \"connectedAt\",\n            \"connectedBy\"\n          ])\n          && request.resource.data.keys().hasOnly([\n            \"jobId\",\n            \"clientId\",\n            \"freelancerId\",\n            \"proposalId\",\n            \"status\",\n            \"createdAt\",\n            \"updatedAt\",\n            \"connectedAt\",\n            \"connectedBy\",\n            \"freelancerName\",\n            \"clientName\",\n            \"clientPhotoURL\",\n            \"freelancerPhotoURL\",\n            \"jobTitle\"\n          ])\n          && jobDoc(request.resource.data.jobId).data.clientId == request.auth.uid\n          && jobDoc(request.resource.data.jobId).data.status == \"approved\"\n          && !hasText(jobDoc(request.resource.data.jobId).data.projectId)\n          && proposalDoc(request.resource.data.proposalId).data.jobId\n            == request.resource.data.jobId\n          && proposalDoc(request.resource.data.proposalId).data.clientId\n            == request.auth.uid\n          && proposalDoc(request.resource.data.proposalId).data.freelancerId\n            == request.resource.data.freelancerId\n          && proposalDoc(request.resource.data.proposalId).data.status\n            in [\"pending\", \"approved\"]);\n      allow read: if isAdmin() || isProjectMember(projectId);\n      allow update, delete: if isAdmin();\n    }\n\n    match /payments/{paymentId} {\n      allow create: if isAdmin()\n        || (isClientApproved()\n            && request.resource.data.receiverType == \"admin\"\n            && request.resource.data.payerId == request.auth.uid\n            && request.resource.data.clientId == request.auth.uid\n            && (isConnectedProject(request.resource.data.projectId)\n              || request.resource.data.sourceFlow == \"contract_full_payment\")\n            && projectDoc(request.resource.data.projectId).data.clientId\n              == request.auth.uid\n            && request.resource.data.status in [\"pending\", \"paid\", \"held\", \"escrow\"]);\n      allow read: if isAdmin()\n        || (isClient()\n            && (resource.data.payerId == request.auth.uid\n              || resource.data.clientId == request.auth.uid))\n        || (isFreelancer() && resource.data.freelancerId == request.auth.uid);\n      allow update: if isAdmin()\n        || (isClientApproved()\n          && resource.data.clientId == request.auth.uid\n          && resource.data.status in [\"escrow\", \"held\"]\n          && request.resource.data.status == \"release_pending\"\n          && request.resource.data.releaseRequestedAt == request.time\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n            \"status\",\n            \"releaseRequestedAt\",\n            \"updatedAt\"\n          ]));\n      allow delete: if isAdmin();\n    }\n\n    match /escrow/{escrowId} {\n      allow create, update, delete: if isAdmin();\n      allow read: if isAdmin();\n    }\n\n    match /payouts/{payoutId} {\n      allow create: if isClient()\n        && request.resource.data.status == \"pending\"\n        && hasText(request.resource.data.contractId)\n        && contractDoc(request.resource.data.contractId).data.clientId == request.auth.uid\n        && request.resource.data.freelancerId\n          == contractDoc(request.resource.data.contractId).data.freelancerId;\n      allow read: if isAdmin()\n        || (isFreelancer() && resource.data.freelancerId == request.auth.uid)\n        || (isClient()\n          && contractDoc(resource.data.contractId).data.clientId == request.auth.uid);\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n\n    match /transactions/{transactionId} {\n      allow read, write: if isAdmin();\n    }\n\n    match /disputes/{disputeId} {\n      allow create: if (isClient() || isFreelancer())\n        && request.resource.data.raisedBy == request.auth.uid\n        && request.resource.data.status == \"open\"\n        && isConnectedProjectMember(request.resource.data.projectId);\n      allow read: if isAdmin() || isConnectedProjectMember(resource.data.projectId);\n      allow update, delete: if isAdmin();\n    }\n\n    match /projectUpdates/{updateId} {\n      allow create: if isConnectedProjectMember(request.resource.data.projectId)\n        && request.resource.data.requestedBy == request.auth.uid\n        && request.resource.data.status == \"pending\";\n      allow read: if isAdmin() || isConnectedProjectMember(resource.data.projectId);\n      allow update, delete: if isAdmin();\n    }\n\n    match /activityLogs/{logId} {\n      allow create: if signedIn()\n        && request.resource.data.actor == request.auth.uid;\n      allow read: if isAdmin();\n      allow update, delete: if false;\n    }\n\n    match /messages/{messageId} {\n      allow create: if isConnectedProjectMember(request.resource.data.projectId)\n        && request.resource.data.senderId == request.auth.uid;\n      allow read: if isAdmin() || isConnectedProjectMember(resource.data.projectId);\n      allow update, delete: if false;\n    }\n\n    match /settings/{docId} {\n      allow read: if signedIn();\n      allow write: if isAdmin();\n    }\n\n    match /notifications/{notificationId} {\n      allow create: if isAdmin() || isNotificationActorWrite();\n      allow read: if isAdmin()\n        || (signedIn() && resource.data.recipientId == request.auth.uid);\n      allow update: if isAdmin()\n        || (signedIn()\n          && resource.data.recipientId == request.auth.uid\n          && request.resource.data.recipientId == resource.data.recipientId);\n      allow delete: if false;\n    }\n\n    match /contracts/{contractId} {\n      function normalizeContractStatus(value) {\n        let text = lower(string(value));\