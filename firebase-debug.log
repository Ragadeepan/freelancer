[debug] [2026-03-04T05:49:15.907Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/freelancer-99659/rulesets {"name":"projects/freelancer-99659/rulesets/ec81cd25-e8c0-44a7-a4f9-91fc7b3edb7f","source":{"files":[{"content":"rules_version = '2';\nservice firebase.storage {\n  match /b/{bucket}/o {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function userDoc() {\n      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));\n    }\n\n    function isApproved() {\n      return signedIn() && userDoc().data.status == \"approved\";\n    }\n\n    function isAdmin() {\n      return isApproved() && userDoc().data.role == \"admin\";\n    }\n\n    function projectDoc(projectId) {\n      return firestore.get(/databases/(default)/documents/projects/$(projectId));\n    }\n\n    function isProjectMember(projectId) {\n      return isApproved()\n        && (projectDoc(projectId).data.clientId == request.auth.uid\n          || projectDoc(projectId).data.freelancerId == request.auth.uid);\n    }\n\n    function contractDoc(contractId) {\n      return firestore.get(/databases/(default)/documents/contracts/$(contractId));\n    }\n\n    function isContractClient(contractId) {\n      return signedIn() && contractDoc(contractId).data.clientId == request.auth.uid;\n    }\n\n    function isContractFreelancer(contractId) {\n      return signedIn() && contractDoc(contractId).data.freelancerId == request.auth.uid;\n    }\n\n    function isContractMember(contractId) {\n      return isContractClient(contractId) || isContractFreelancer(contractId);\n    }\n\n    function workspaceSectionWriteAllowed(contractId, section) {\n      return (section == \"requirements\" && isContractClient(contractId))\n        || (section == \"client\" && isContractClient(contractId))\n        || (section == \"freelancer\" && isContractFreelancer(contractId));\n    }\n\n    function workspaceMimeAllowed(contentType) {\n      return contentType in [\n        \"application/pdf\",\n        \"application/msword\",\n        \"application/vnd.openxmlformats-officedocument.wordprocessingml.document\",\n        \"application/zip\",\n        \"application/x-zip-compressed\",\n        \"image/png\",\n        \"image/jpg\",\n        \"image/jpeg\",\n        \"image/pjpeg\"\n      ];\n    }\n\n    function workspaceNameAllowed(fileName) {\n      return fileName.matches(\".*\\\\.(pdf|doc|docx|zip|png|jpg|jpeg)$\");\n    }\n\n    match /projectFiles/{projectId}/{fileName} {\n      allow read: if isAdmin() || isProjectMember(projectId);\n      allow write: if isAdmin()\n        || (signedIn() && projectDoc(projectId).data.freelancerId == request.auth.uid);\n    }\n\n    match /userCertificates/{uid}/{fileName} {\n      allow write: if signedIn() && request.auth.uid == uid;\n      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);\n    }\n\n    match /userResumes/{uid}/{fileName} {\n      allow write: if signedIn() && request.auth.uid == uid;\n      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);\n    }\n\n    match /userGovIds/{uid}/{fileName} {\n      allow write: if signedIn() && request.auth.uid == uid;\n      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);\n    }\n\n    match /userClientGovIds/{uid}/{fileName} {\n      allow write: if signedIn() && request.auth.uid == uid;\n      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);\n    }\n\n    match /userClientDocuments/{uid}/{fileName} {\n      allow write: if signedIn() && request.auth.uid == uid;\n      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);\n    }\n\n    match /profilePictures/{uid}/{fileName} {\n      allow write: if signedIn() && request.auth.uid == uid;\n      allow read: if isAdmin() || signedIn();\n    }\n\n    match /contracts/{contractId}/{section}/{fileName} {\n      allow read: if isContractMember(contractId);\n      allow write: if workspaceSectionWriteAllowed(contractId, section)\n        && workspaceNameAllowed(fileName)\n        && request.resource.size <= 20 * 1024 * 1024\n        && (\n          request.resource.contentType == null\n          || request.resource.contentType == \"\"\n          || workspaceMimeAllowed(request.resource.contentType)\n        );\n    }\n\n    match /contractRequirements/{contractId}/{fileName} {\n      allow write: if isContractClient(contractId);\n      allow read: if isAdmin() || isContractClient(contractId) || isContractFreelancer(contractId);\n    }\n\n    match /contractFlows/{contractId}/{fileName} {\n      allow write: if isContractFreelancer(contractId);\n      allow read: if isAdmin() || isContractClient(contractId) || isContractFreelancer(contractId);\n    }\n\n    match /contractFeedback/{contractId}/{fileName} {\n      allow write: if isContractClient(contractId);\n      allow read: if isAdmin() || isContractClient(contractId) || isContractFreelancer(contractId);\n    }\n\n    match /contractFinal/{type}/{contractId}/{fileName} {\n      allow write: if isContractFreelancer(contractId);\n      allow read: if isAdmin() || isContractClient(contractId) || isContractFreelancer(contractId);\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-03-04T05:49:16.468623Z","metadata":{"services":["firebase.storage"]}}
