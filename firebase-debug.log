delete: if false;\n    }\n\n    match /contractFiles/{fileId} {\n      allow read: if signedIn() && isContractMember(resource.data.contractId);\n      allow create: if signedIn()\n        && hasText(request.resource.data.contractId)\n        && isContractMember(request.resource.data.contractId)\n        && request.resource.data.uploadedBy == request.auth.uid\n        && request.resource.data.role in [\"client\", \"freelancer\"]\n        && (\n          (\n            request.resource.data.role == \"client\"\n            && contractDoc(request.resource.data.contractId).data.clientId == request.auth.uid\n          )\n          || (\n            request.resource.data.role == \"freelancer\"\n            && contractDoc(request.resource.data.contractId).data.freelancerId == request.auth.uid\n          )\n        )\n        && hasText(request.resource.data.fileName)\n        && hasText(request.resource.data.fileUrl)\n        && request.resource.data.uploadedAt == request.time;\n      allow update, delete: if false;\n    }\n\n    match /contractActivity/{activityId} {\n      allow read: if signedIn() && isContractMember(resource.data.contractId);\n      allow create: if signedIn()\n        && hasText(request.resource.data.contractId)\n        && isContractMember(request.resource.data.contractId)\n        && request.resource.data.actorId == request.auth.uid\n        && request.resource.data.actorRole in [\"client\", \"freelancer\"]\n        && (\n          (\n            request.resource.data.actorRole == \"client\"\n            && contractDoc(request.resource.data.contractId).data.clientId == request.auth.uid\n          )\n          || (\n            request.resource.data.actorRole == \"freelancer\"\n            && contractDoc(request.resource.data.contractId).data.freelancerId == request.auth.uid\n          )\n        )\n        && request.resource.data.createdAt == request.time;\n      allow update, delete: if false;\n    }\n\n    match /contracts/{contractId} {\n      function normalizeContractStatus(value) {\n        let text = string(value).lower();\n        return text == \"contract_created\" ? \"awaiting_payment\"\n          : text == \"client_paid\" ? \"awaiting_requirements\"\n          : text == \"flow_approved\" ? \"development_ready\"\n          : text == \"development_started\" ? \"in_progress\"\n          : text == \"feedback_uploaded\" ? \"revision_requested\"\n          : text == \"final_approved\" ? \"completed\"\n          : text == \"release_pending\" ? \"completed\"\n          : text == \"released\" ? \"closed\"\n          : text;\n      }\n\n      function normalizePaymentStatus(value) {\n        let text = string(value).lower();\n        return text == \"escrow\" ? \"funded\"\n          : text == \"held\" ? \"funded\"\n          : text == \"released\" ? \"paid\"\n          : text == \"\" ? \"awaiting_payment\"\n          : text;\n      }\n\n      function contractStatusBefore() {\n        return normalizeContractStatus(\n          resource.data.contractStatus != null\n            ? resource.data.contractStatus\n            : resource.data.status\n        );\n      }\n\n      function contractStatusAfter() {\n        return normalizeContractStatus(\n          request.resource.data.contractStatus != null\n            ? request.resource.data.contractStatus\n            : request.resource.data.status\n        );\n      }\n\n      function paymentStatusBefore() {\n        return normalizePaymentStatus(resource.data.paymentStatus);\n      }\n\n      function paymentStatusAfter() {\n        return normalizePaymentStatus(request.resource.data.paymentStatus);\n      }\n\n      function validClientContractTransition() {\n        return (\n          (\n            contractStatusBefore() == \"awaiting_payment\"\n            && contractStatusAfter() == \"awaiting_requirements\"\n            && paymentStatusBefore() == \"awaiting_payment\"\n            && paymentStatusAfter() == \"funded\"\n          )\n          || (\n            contractStatusBefore() == \"awaiting_requirements\"\n            && contractStatusAfter() == \"requirements_uploaded\"\n            && paymentStatusAfter() == paymentStatusBefore()\n          )\n          || (\n            contractStatusBefore() == \"flow_submitted\"\n            && contractStatusAfter() in [\"development_ready\", \"flow_revision\"]\n            && paymentStatusAfter() == paymentStatusBefore()\n          )\n          || (\n            contractStatusBefore() == \"demo_scheduled\"\n            && contractStatusAfter() == \"revision_requested\"\n            && paymentStatusAfter() == paymentStatusBefore()\n          )\n          || (\n            contractStatusBefore() == \"final_submitted\"\n            && contractStatusAfter() == \"completed\"\n            && paymentStatusBefore() == \"funded\"\n            && paymentStatusAfter() == \"release_pending\"\n          )\n          || (\n            contractStatusBefore() == \"awaiting_requirements\"\n            && contractStatusAfter() == \"awaiting_requirements\"\n            && paymentStatusAfter() == paymentStatusBefore()\n          )\n        );\n      }\n\n      function validFreelancerContractTransition() {\n        return (\n          (\n            contractStatusBefore() in [\"requirements_uploaded\", \"flow_revision\"]\n            && contractStatusAfter() == \"flow_submitted\"\n            && paymentStatusAfter() == paymentStatusBefore()\n          )\n          || (\n            contractStatusBefore() == \"development_ready\"\n            && contractStatusAfter() == \"in_progress\"\n            && paymentStatusAfter() == paymentStatusBefore()\n          )\n          || (\n            contractStatusBefore() == \"in_progress\"\n            && contractStatusAfter() == \"demo_scheduled\"\n            && paymentStatusAfter() == paymentStatusBefore()\n          )\n          || (\n            contractStatusBefore() in [\"revision_requested\", \"in_progress\"]\n            && contractStatusAfter() == \"final_submitted\"\n            && paymentStatusAfter() == paymentStatusBefore()\n          )\n        );\n      }\n\n      allow read: if isAdmin() || isContractMember(contractId);\n      allow create: if signedIn()\n        && request.resource.data.clientId == request.auth.uid\n        && request.resource.data.contractStatus == \"awaiting_payment\"\n        && request.resource.data.paymentStatus == \"awaiting_payment\";\n      allow update: if isAdmin()\n        || (signedIn()\n          && request.auth.uid == resource.data.clientId\n          && request.resource.data.clientId == resource.data.clientId\n          && validClientContractTransition()\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n            \"contractStatus\",\n            \"paymentStatus\",\n            \"paymentId\",\n            \"requirementFile\",\n            \"requirementUploadedAt\",\n            \"requirementDeadline\",\n            \"flowApprovedAt\",\n            \"flowApprovedBy\",\n            \"flowRevisionRequestedAt\",\n            \"flowRevisionRequestedBy\",\n            \"flowRevisionReason\",\n            \"feedbackDoc\",\n            \"feedbackUploadedAt\",\n            \"finalApprovedAt\",\n            \"finalApprovedBy\",\n            \"cancellationRequestedAt\",\n            \"cancellationRequestedBy\",\n            \"updatedAt\"\n          ]))\n        || (signedIn()\n          && request.auth.uid == resource.data.freelancerId\n          && request.resource.data.freelancerId == resource.data.freelancerId\n          && validFreelancerContractTransition()\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n            \"contractStatus\",\n            \"flowDoc\",\n            \"flowSubmittedAt\",\n            \"developmentStartedAt\",\n            \"demoScheduledAt\",\n            \"demoDate\",\n            \"demoTime\",\n            \"meetingLink\",\n            \"finalSubmission\",\n            \"finalSub